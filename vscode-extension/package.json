{
  "name": "ai-emos",
  "displayName": "ai-emos",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "SieteAses",
  "license": "MIT",
  "author": { "name": "Vicente Díaz", "email": "vicentediazg@gmail.com" },
  "repository": { "type": "git", "url": "https://github.com/SieteAses/ai-emos.git", "directory": "vscode-extension" },
  "bugs": { "url": "https://github.com/SieteAses/ai-emos/issues" },
  "homepage": "https://github.com/SieteAses/ai-emos#readme",
  "galleryBanner": { "color": "#0b0d11", "theme": "dark" },
  "icon": "bundled/icon.png",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Visualization", "Other"],
  "keywords": ["observability", "agents", "timeline", "claude-code", "opentelemetry", "ia"],
  "main": "./extension.js",
  "activationEvents": ["onUri"],
  "scripts": {
    "bundle": "node bundle.mjs",
    "vscode:prepublish": "node bundle.mjs"
  },
  "contributes": {
    "commands": [
      {
        "command": "aiEmos.sessions",
        "title": "%cmd.sessions.title%",
        "category": "ai-emos"
      },
      {
        "command": "aiEmos.openFile",
        "title": "%cmd.openFile.title%",
        "category": "ai-emos"
      },
      {
        "command": "aiEmos.liveSession",
        "title": "%cmd.liveSession.title%",
        "category": "ai-emos"
      }
    ],
    "configuration": {
      "title": "ai-emos",
      "properties": {
        "aiEmos.criteria.tokens.turnBudget": {
          "type": "number",
          "default": 80000,
          "description": "%config.tokens.turnBudget%"
        },
        "aiEmos.criteria.tokens.agentBudget": {
          "type": "number",
          "default": 150000,
          "description": "%config.tokens.agentBudget%"
        },
        "aiEmos.criteria.durationMs.tool": {
          "type": "number",
          "default": 30000,
          "description": "%config.durationMs.tool%"
        },
        "aiEmos.criteria.durationMs.agent": {
          "type": "number",
          "default": 300000,
          "description": "%config.durationMs.agent%"
        },
        "aiEmos.criteria.baseline.sigma": {
          "type": "number",
          "default": 2,
          "description": "%config.baseline.sigma%"
        }
      }
    }
  }
}
